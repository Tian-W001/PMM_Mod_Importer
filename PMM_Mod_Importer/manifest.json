{
    "name": "PeakyModManager Mod Importer",
    "description": "A mod importer for PeakyModManager that allows users to easily import mods from GameBanana.",
    "version": "0.0.0.2",
    "manifest_version": 3,
    "author": "Peaky",
    "icons": {
        "128": "icon128.png"
    },
    "permissions": ["activeTab", "scripting"],
    "host_permissions": [
        "https://gamebanana.com/mods/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://gamebanana.com/mods/*"],
            "js": ["content.js"]
        }
    ]
}